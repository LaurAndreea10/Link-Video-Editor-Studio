{
  "name": "link-video-editor-studio",
  "version": "1.0.0",
  "description": "Static-first GitHub Pages studio with Playwright render workflows",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "install:browsers": "playwright install chromium",
    "validate": "node --check assets/app.js && node -e \"JSON.parse(require('fs').readFileSync('assets/presets.json','utf8')); console.log('presets.json valid')\"",
    "render:plan": "node scripts/run-plan.mjs"
  },
  "dependencies": {
    "express": "^4.21.2",
    "playwright": "^1.53.0",
    "uuid": "^11.1.0"
  }
}
